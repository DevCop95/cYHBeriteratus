# Port the web interface listens on
APP_PORT=4000

# Ollama host and port
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# Default model (must be installed in Ollama)
OLLAMA_MODEL=richardyoung/qwen2.5-3b-instruct-abliterated

# Number of layers on GPU (null = auto, 0 = force CPU)
# OLLAMA_NUM_GPU=0

# Log level: DEBUG | INFO | WARN | ERROR (default: INFO)
# LOG_LEVEL=DEBUG
