# Puerto en que escucha la interfaz web
APP_PORT=4000

# Host y puerto de Ollama
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# Modelo por defecto (debe estar instalado en Ollama)
OLLAMA_MODEL=richardyoung/qwen2.5-3b-instruct-abliterated

# Número de capas en GPU (null = auto, 0 = forzar CPU)
# OLLAMA_NUM_GPU=0

# Nivel de log: DEBUG | INFO | WARN | ERROR (defecto: INFO)
# LOG_LEVEL=DEBUG
